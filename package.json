{
  "name": "@nolawnchairs/effects-nestjs",
  "version": "1.0.2",
  "keywords": [],
  "description": "NestJS module for controller-based effect dispatching",
  "main": "lib/index.js",
  "author": "Mike <nolawnchairs@gmail.com>",
  "homepage": "https://github.com/nolawnchairs/nestjs-effects",
  "repository": {
    "type": "git",
    "url": "https://github.com/nolawnchairs/nestjs-effects.git"
  },
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "test",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.ts"
    ],
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@knightinteractive/eslint-plugin": "^1.2.0",
    "@nestjs/common": "^9.0.0",
    "@nestjs/core": "^9.0.0",
    "@nestjs/platform-express": "^9.4.3",
    "@nestjs/testing": "^9.0.0",
    "@types/express": "^4.17.13",
    "@types/jest": "^29.4.0",
    "@types/node": "^18.14.6",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "eslint": "^8.48.0",
    "jest": "^29.6.1",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^4.4.0",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.1.6"
  },
  "peerDependencies": {
    "@nestjs/common": ">= 9",
    "@nestjs/core": ">= 9",
    "@nestjs/event-emitter": ">= 1",
    "reflect-metadata": ">= 0.1.13",
    "rxjs": ">= 7.0.0"
  },
  "engines": {
    "node": ">= 16.0.0"
  },
  "scripts": {
    "build": "npm run prebuild && tsc",
    "lint": "eslint --ext .ts .",
    "lint:fix": "eslint --fix --ext .ts .",
    "prebuild": "rm -rf ./lib",
    "test-runner": "jest --watchAll",
    "test": "jest"
  }
}